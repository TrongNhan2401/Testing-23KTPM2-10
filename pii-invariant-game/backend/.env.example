# ============================================================================
# pii-invariant-game / backend / .env.example
# ============================================================================
# Copy this file to `.env` and fill in the real values.
# Never commit `.env` to source control.
# ============================================================================

# Server
NODE_ENV=development
PORT=3000

# MongoDB Atlas
# Get this from Atlas → Cluster → "Connect" → "Drivers" (Node.js)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=...
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?appName=pii-sentinel-backend

# Name of the logical database inside the Atlas cluster.
# All collections (groups, piiQuestions, ..., leaderboard) live inside this DB.
MONGODB_DB_NAME=pii-sentinel

# Game session duration in seconds. Default is 600 (10 minutes).
# Must be between 1 and 14400 (4 hours) to satisfy the gameSessions validator.
GAME_DURATION_SECONDS=600
